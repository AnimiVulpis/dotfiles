{
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[dockercompose]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[markdown]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "[toml]": {
    "editor.defaultFormatter": "tombi-toml.tombi"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "chat.agent.enabled": true,
  "chat.viewSessions.orientation": "stacked",
  "diffEditor.experimental.showMoves": true,
  "diffEditor.experimental.useTrueInlineView": true,
  "docker.extension.enableComposeLanguageServer": false,
  "editor.cursorBlinking": "solid",
  "editor.cursorSurroundingLines": 5,
  "editor.dragAndDrop": false,
  "editor.find.autoFindInSelection": "multiline",
  "editor.fontFamily": "'IosevkaTerm Nerd Font', 'Droid Sans Mono', 'monospace', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.guides.bracketPairs": true,
  "editor.guides.highlightActiveIndentation": "always",
  "editor.linkedEditing": true,
  "editor.minimap.showSlider": "always",
  "editor.renderWhitespace": "boundary",
  "editor.roundedSelection": false,
  "editor.semanticTokenColorCustomizations": {
    "[Default Dark+]": {
      "rules": {
        "property.mandatory:xml": {
          "bold": true
        },
        "string.i18n:xml": {
          "italic": true
        }
      }
    },
    "[Default High Contrast]": {
      "rules": {
        "property.mandatory:xml": {
          "bold": true
        },
        "string.i18n:xml": {
          "italic": true
        }
      }
    },
    "[Default Light+]": {
      "rules": {
        "property.mandatory:xml": {
          "bold": true
        },
        "string.i18n:xml": {
          "italic": true
        }
      }
    }
  },
  "editor.showFoldingControls": "always",
  "editor.smoothScrolling": true,
  "editor.suggest.localityBonus": true,
  "editor.suggest.showStatusBar": true,
  "git.blame.editorDecoration.enabled": false,
  "github.copilot.chat.agent.thinkingTool": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.selectedCompletionModel": "",
  "harper.codeActions.ForceStable": true,
  "harper.dialect": "British",
  "harper.excludePatterns": [
    "*.typ"
  ],
  "harper.linters.AsFarAsIKnow": false,
  "harper.linters.AsSoonAsPossible": false,
  "harper.linters.BeRightBack": false,
  "harper.linters.ByTheWay": false,
  "harper.linters.Cybersec": false,
  "harper.linters.Dashes": false,
  "harper.linters.ExpandArgument": false,
  "harper.linters.ExpandBecause": false,
  "harper.linters.ExpandControl": false,
  "harper.linters.ExpandDecl": false,
  "harper.linters.ExpandDependencies": false,
  "harper.linters.ExpandDeref": false,
  "harper.linters.ExpandForward": false,
  "harper.linters.ExpandMemoryShorthands": false,
  "harper.linters.ExpandMinimum": false,
  "harper.linters.ExpandParameter": false,
  "harper.linters.ExpandPointer": false,
  "harper.linters.ExpandPrevious": false,
  "harper.linters.ExpandStandardInputAndOutput": false,
  "harper.linters.ExpandTimeShorthands": false,
  "harper.linters.ExpandWith": false,
  "harper.linters.ExpandWithout": false,
  "harper.linters.ExplainLikeImFive": false,
  "harper.linters.ForWhatItsWorth": false,
  "harper.linters.ForYourInformation": false,
  "harper.linters.IDontKnow": false,
  "harper.linters.IfIRecallCorrectly": false,
  "harper.linters.IfIUnderstandCorrectly": false,
  "harper.linters.IfYouKnowYouKnow": false,
  "harper.linters.InCaseYouMissedIt": false,
  "harper.linters.InMyHumbleOpinion": false,
  "harper.linters.InMyOpinion": false,
  "harper.linters.InRealLife": false,
  "harper.linters.LongSentences": false,
  "harper.linters.NeverMind": false,
  "harper.linters.OhMyGod": false,
  "harper.linters.OrthographicConsistency": false,
  "harper.linters.PhrasalVerbAsCompoundNoun": false,
  "harper.linters.PleaseTakeALook": false,
  "harper.linters.SentenceCapitalization": false,
  "harper.linters.Spaces": false,
  "harper.linters.SplitWords": false,
  "harper.linters.UnclosedQuotes": false,
  "harper.linters.UseTitleCase": false,
  "harper.userDictPath": "~/.config/harper-ls/dictionary.txt",
  "hediet.vscode-drawio.appearance": "light",
  "hediet.vscode-drawio.customLibraries": [
    {
      "entryId": "TAM_AD",
      "file": "<TAM-repo>/build/TAM-AD.xml",
      "libName": "TAM Activity Diagram"
    },
    {
      "entryId": "TAM_Ann",
      "file": "<TAM-repo>/build/TAM-Ann.xml",
      "libName": "TAM Annotations"
    },
    {
      "entryId": "TAM_BD",
      "file": "<TAM-repo>/build/TAM-BD.xml",
      "libName": "TAM Block Diagram"
    },
    {
      "entryId": "TAM_CD",
      "file": "<TAM-repo>/build/TAM-CD.xml",
      "libName": "TAM Class Diagramm"
    },
    {
      "entryId": "TAM_SeqD",
      "file": "<TAM-repo>/build/TAM-SeqD.xml",
      "libName": "TAM Sequence Diagram"
    }
  ],
  "hediet.vscode-drawio.resizeImages": null,
  "keyboard.touchbar.enabled": false,
  "material-icon-theme.activeIconPack": "none",
  "npm.fetchOnlinePackageInfo": false,
  "scm.diffDecorationsGutterPattern": {
    "added": true
  },
  "search.exclude": {
    "**/build": true,
    "**/dist": true,
    "**/target": true
  },
  "search.useIgnoreFiles": false,
  "security.workspace.trust.untrustedFiles": "newWindow",
  "shellformat.effectLanguages": [
    "shellscript",
    "dockerfile",
    "dotenv",
    "hosts",
    "jvmoptions",
    "ignore",
    "gitignore",
    "properties",
    "spring-boot-properties",
    "azcli",
    "bats"
  ],
  "telemetry.editStats.enabled": false,
  "telemetry.feedback.enabled": false,
  "telemetry.telemetryLevel": "off",
  "terminal.external.linuxExec": "wezterm",
  "terminal.integrated.scrollback": 42000,
  "tinymist.lint.enabled": true,
  "window.density.editorTabHeight": "compact",
  "window.newWindowProfile": "Default",
  "window.title": "${rootName}${separator}${activeEditorMedium}${dirty}",
  "workbench.activityBar.location": "top",
  // Add the following config to your ~/.config/Code/Usersettings.json file.
  // Root Loops: https://rootloops.sh?sugar=6&colors=9&sogginess=9&flavor=1&fruit=7&milk=1
  //
  // NOTE: I take only workbench.colorCustomizations.terminal.*
  "workbench.colorCustomizations": {
    "terminal.ansiBlack": "#053e46",
    "terminal.ansiBlue": "#2d83e8",
    "terminal.ansiBrightBlack": "#0e6774",
    "terminal.ansiBrightBlue": "#509af6",
    "terminal.ansiBrightCyan": "#1faeae",
    "terminal.ansiBrightGreen": "#67af34",
    "terminal.ansiBrightMagenta": "#ca64f3",
    "terminal.ansiBrightRed": "#f75b72",
    "terminal.ansiBrightWhite": "#51e0f7",
    "terminal.ansiBrightYellow": "#c98b1a",
    "terminal.ansiCyan": "#1a9696",
    "terminal.ansiGreen": "#59972d",
    "terminal.ansiMagenta": "#ba3ce8",
    "terminal.ansiRed": "#e73359",
    "terminal.ansiWhite": "#20b4c9",
    "terminal.ansiYellow": "#ae7714",
    "terminal.background": "#02272c",
    "terminal.foreground": "#7ce9fb",
    "terminalCursor.foreground": "#20b4c9"
  },
  "workbench.colorTheme": "Monokai",
  "workbench.commandPalette.experimental.suggestCommands": true,
  "workbench.commandPalette.preserveInput": true,
  "workbench.editor.empty.hint": "hidden",
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.iconTheme": "material-icon-theme",
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.settings.enableNaturalLanguageSearch": false,
  "workbench.settings.openDefaultKeybindings": true,
  "workbench.settings.openDefaultSettings": true,
  "workbench.startupEditor": "none",
  "workbench.tree.renderIndentGuides": "always",
  "zenMode.fullScreen": false,
  "zenMode.restore": false,
  "zenMode.silentNotifications": false
}