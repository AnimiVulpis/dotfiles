// Gram keymap
//
// For information on binding keys, see the Gram
// documentation: gram://docs/key-bindings
//
// To see the default key bindings run `gram: open default keymap`
// from the command palette.
[
  {
    "context": "Editor && mode == full",
    "use_key_equivalents": true,
    "bindings": {
      "tab": "editor::SuperTab",
    },
  },
]
